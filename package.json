{
  "name": "metrorail-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite dev --port 3000",
    "dev:server": "pnpm dlx convex dev",
    "build": "vite build",
    "build:clean": "rm -rf dist && vite build",
    "preview": "vite preview",
    "unit:test": "vitest run",
    "e2e:test": "vitest run --config vitest.e2e.config.ts",
    "deploy": "pnpm run build:clean && wrangler deploy",
    "deploy:fresh": "rm -rf dist .wrangler && pnpm run build && wrangler deploy",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "upload:data": "pnpm dlx convex run seed/run:execute",
    "clear:data": "pnpm dlx convex run seed/clear:run"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@convex-dev/react-query": "0.1.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.27.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.561.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.40.3"
  }
}